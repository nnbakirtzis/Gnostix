AI_PROVIDER=ollama # Choose between 'gemini' or 'ollama'
GEMINI_API_KEY= # your Gemini API key from Google AI Studio (only needed when AI_PROVIDER=gemini)

# PostgreSQL connection string (local Docker setup: see docker-compose.yml)
DATABASE_URL="postgresql://gnostix:gnostix@localhost:5432/gnostix?schema=public"

# Ollama settings (only needed when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b # chat model — Gemma 4 variants: e2b (≥8GB RAM) / e4b (≥16GB RAM)
OLLAMA_EMBED_MODEL=nomic-embed-text # embedding model for RAG (768-dim)
OLLAMA_NUM_CTX=65536 # context window (Gemma 4 supports up to 128K)
